.rice-cell.data-v-4bd22bab {
  --rice-cell-title-size: 15px;
  --rice-cell-value-size: 15px;
  --rice-cell-label-size: 13px;
  flex-direction: row;
  padding: 14px var(--rice-padding-md);
  background-color: var(--rice-cell-background);
  width: 100%;
}
.rice-cell--medium.data-v-4bd22bab {
  --rice-cell-title-size: 16px;
  --rice-cell-value-size: 16px;
  --rice-cell-label-size: 14px;
}
.rice-cell--large.data-v-4bd22bab {
  --rice-cell-title-size: 17px;
  --rice-cell-value-size: 17px;
  --rice-cell-label-size: 15px;
  padding: var(--rice-font-size-lg);
}
.rice-cell__title.data-v-4bd22bab {
  flex: 1;
  padding-right: 2px;
}
.rice-cell__title__text.data-v-4bd22bab {
  line-height: 1.6;
  color: var(--rice-text-color);
  font-size: var(--rice-cell-title-size);
  word-wrap: break-word;
}
.rice-cell__value.data-v-4bd22bab {
  flex: 1;
  padding-right: 2px;
  text-align: right;
  word-break: break-all;
}
.rice-cell__value__text.data-v-4bd22bab {
  line-height: 1.6;
  color: var(--rice-text-color-2);
  font-size: var(--rice-cell-value-size);
  text-align: right;
  word-wrap: break-word;
}
.rice-cell__label.data-v-4bd22bab {
  color: var(--rice-text-color-2);
  font-size: var(--rice-cell-label-size);
  margin-top: 5px;
  word-wrap: break-word;
}
.rice-cell--center.data-v-4bd22bab {
  align-items: center;
}
.rice-cell--border.data-v-4bd22bab {
  position: relative;
}
.rice-cell--border.data-v-4bd22bab::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
  pointer-events: none;
  left: 0;
  right: 0;
  bottom: 0;
  border-bottom: 1px solid var(--rice-border-color);
  transform: scaleY(0.5);
}
.rice-cell--hover.data-v-4bd22bab {
  background-color: var(--rice-hover-color);
}