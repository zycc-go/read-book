.rice-avatar.data-v-e0e31555 {
  flex-direction: row;
  align-items: center;
  justify-content: center;
  height: 48px;
  width: 48px;
  border-radius: var(--rice-radius-sm);
}
.rice-avatar--round.data-v-e0e31555 {
  border-radius: 999px;
}
.rice-avatar--mini.data-v-e0e31555 {
  height: 40px;
  width: 40px;
}
.rice-avatar--large.data-v-e0e31555 {
  height: 62px;
  width: 62px;
}
.rice-avatar__image.data-v-e0e31555 {
  height: 100%;
  width: 100%;
  border-radius: var(--rice-radius-sm);
}
.rice-avatar--text.data-v-e0e31555, .rice-avatar--loading.data-v-e0e31555, .rice-avatar--error.data-v-e0e31555 {
  background-color: var(--rice-image-placeholder-background);
}