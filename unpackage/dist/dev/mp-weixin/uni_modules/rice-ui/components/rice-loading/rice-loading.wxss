.rice-loading.data-v-55e28e25 {
  flex-direction: row;
  align-items: center;
}
.rice-loading--vertical.data-v-55e28e25 {
  flex-direction: column;
  justify-content: center;
}
.rice-loading--slot.data-v-55e28e25 {
  overflow: visible;
}
.rice-loading--semicircle.data-v-55e28e25 {
  border-radius: 999px;
  border: 2px solid transparent;
  border-top-color: var(--31e842e0);
  animation: rotate-55e28e25 var(--7ace60c0) ease-in-out infinite;
}
.rice-loading--circle.data-v-55e28e25 {
  border-radius: 999px;
  border: 2px solid rgba(25, 136, 249, 0.2);
  border-top-color: var(--31e842e0);
  animation: rotate-55e28e25 var(--7ace60c0) ease-in-out infinite;
}
.rice-loading--circular.data-v-55e28e25 {
  color: var(--31e842e0);
  border-radius: 100%;
  animation: rotate-55e28e25 var(--7ace60c0) linear infinite;
  background: conic-gradient(from 180deg at 50% 50%, rgba(255, 255, 255, 0) 0deg, rgba(255, 255, 255, 0) 60deg, currentColor 330deg, rgba(255, 255, 255, 0) 360deg);
  -webkit-mask: radial-gradient(transparent calc(50% - 1rpx), #fff 50%);
          mask: radial-gradient(transparent calc(50% - 1rpx), #fff 50%);
}
.rice-loading--snow.data-v-55e28e25 {
  animation: rotate-55e28e25 var(--7ace60c0) linear infinite;
}
.rice-loading__text.data-v-55e28e25 {
  font-size: var(--rice-font-size-sm);
  color: var(--rice-text-color-2);
}
@keyframes rotate-55e28e25 {
from {
    transform: rotate(0deg);
}
to {
    transform: rotate(360deg);
}
}