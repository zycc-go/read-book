.rice-grid-item.data-v-16bc1954 {
  padding: var(--rice-padding-sm) var(--rice-padding-xs);
  background-color: var(--rice-grid-background);
  box-sizing: border-box;
  align-items: center;
  justify-content: center;
}
.rice-grid-item__text.data-v-16bc1954 {
  font-size: var(--rice-font-size-sm);
  color: var(--rice-text-color);
  margin-top: 6px;
  text-align: center;
  word-break: break-all;
}
.rice-grid-item--horizontal.data-v-16bc1954 {
  flex-direction: row;
  justify-content: center;
}
.rice-grid-item--horizontal .rice-grid-item__text.data-v-16bc1954 {
  margin-top: 0px;
  margin-left: 6px;
  text-align: left;
  flex: 0 1 auto;
}
.rice-grid-item--border--bottom.data-v-16bc1954 {
  position: relative;
}
.rice-grid-item--border--bottom.data-v-16bc1954::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
  pointer-events: none;
  left: 0;
  right: 0;
  bottom: 0;
  border-bottom: 1px solid var(--rice-border-color);
  transform: scaleY(0.5);
}
.rice-grid-item--border--right.data-v-16bc1954 {
  position: relative;
}
.rice-grid-item--border--right.data-v-16bc1954::before {
  content: "";
  position: absolute;
  box-sizing: border-box;
  pointer-events: none;
  top: 0;
  bottom: 0;
  right: 0;
  border-right: 1px solid var(--rice-border-color);
  transform: scaleX(0.5);
}
.rice-grid-item--hover.data-v-16bc1954 {
  background-color: var(--rice-hover-color);
}