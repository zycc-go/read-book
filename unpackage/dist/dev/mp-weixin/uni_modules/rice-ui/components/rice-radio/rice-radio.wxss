.rice-radio.data-v-030527c2 {
  flex-direction: row;
  align-items: center;
}
.rice-radio__icon.data-v-030527c2 {
  flex-direction: row;
  align-items: center;
  justify-content: center;
  transition: all 100ms ease-in-out;
  width: 20px;
  height: 20px;
  border: 1px solid var(--rice-radio-border-color);
  border-radius: 4px;
  background-color: transparent;
}
.rice-radio__icon--disabled.data-v-030527c2 {
  background-color: var(--rice-radio-disabled-background);
  border: 1px solid var(--rice-radio-disabled-border-color);
}
.rice-radio__icon--checked.data-v-030527c2 {
  background-color: var(--rice-primary-color);
  border: 1px solid var(--rice-primary-color);
}
.rice-radio__icon--checked--disabled.data-v-030527c2 {
  background-color: var(--rice-primary-color);
  border: 1px solid var(--rice-primary-color);
  opacity: 0.4;
}
.rice-radio__icon--round.data-v-030527c2 {
  border-radius: 999px;
}
.rice-radio__label.data-v-030527c2 {
  flex: 0 1 auto;
}
.rice-radio__label--left.data-v-030527c2 {
  padding-left: 8px;
}
.rice-radio__label--right.data-v-030527c2 {
  padding-right: 8px;
}
.rice-radio__label__text.data-v-030527c2 {
  font-size: var(--rice-font-size-basic);
  color: var(--rice-text-color);
}
.rice-radio__label__text--disabled.data-v-030527c2 {
  color: var(--rice-radio-label-disabled-color);
}
.rice-radio--row.data-v-030527c2 {
  margin-right: var(--rice-padding-sm);
  flex: 0 1 auto;
}
.rice-radio--space-between.data-v-030527c2 {
  justify-content: space-between;
}