.rice-switch.data-v-2d10b861 {
  position: relative;
  flex-direction: row;
  align-items: center;
  border-radius: 200px;
  height: 28px;
  width: 50px;
  box-sizing: border-box;
  transition-property: color, background-color;
  transition-duration: 300ms;
  background-color: var(--rice-switch-background);
  color: var(--rice-switch-background);
}
.rice-switch__inner.data-v-2d10b861 {
  width: 100%;
  transition: padding 300ms;
  padding: 0 6px 0 28px;
  box-sizing: border-box;
}
.rice-switch__inner__text.data-v-2d10b861 {
  font-size: 12px;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
}
.rice-switch__inner--active.data-v-2d10b861 {
  padding: 0 28px 0 6px;
}
.rice-switch__node.data-v-2d10b861 {
  position: absolute;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  background-color: #fff;
  height: 22px;
  width: 22px;
  border-radius: 200px;
  transition: transform 300ms;
  box-shadow: 0 2px 3px rgba(0, 0, 0, 0.2);
}
.rice-switch__node__text.data-v-2d10b861 {
  font-size: 12px;
  transition: color 300ms;
  white-space: nowrap;
  text-align: center;
  width: 100%;
}
.rice-switch--active.data-v-2d10b861 {
  background-color: var(--rice-primary-color);
  color: var(--rice-primary-color);
}
.rice-switch--disabled.data-v-2d10b861 {
  opacity: 0.6;
}