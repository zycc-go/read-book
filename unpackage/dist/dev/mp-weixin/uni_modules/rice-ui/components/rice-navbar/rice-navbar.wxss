.rice-navbar.data-v-abe06922 {
  position: relative;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  background-color: var(--rice-navbar-background);
  height: 44px;
  box-sizing: content-box;
  width: 100%;
}
.rice-navbar--fixed.data-v-abe06922 {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  width: 100%;
  z-index: 998;
}
.rice-navbar--placeholder.data-v-abe06922 {
  width: 100%;
}
.rice-navbar--border.data-v-abe06922 {
  border-bottom: 1px solid var(--rice-border-color);
}
.rice-navbar--safearea-top.data-v-abe06922 {
  padding-top: var(--2ecd2eaf);
}
.rice-navbar__aside.data-v-abe06922 {
  position: absolute;
  bottom: 0;
  top: 0;
  padding: 0 10px;
  flex-direction: row;
  align-items: center;
  color: var(--rice-text-color);
}
.rice-navbar__aside--safearea-top.data-v-abe06922 {
  top: var(--2ecd2eaf);
}
.rice-navbar__aside__text.data-v-abe06922 {
  font-size: var(--rice-font-size-sm);
  color: var(--rice-text-color);
}
.rice-navbar__left.data-v-abe06922 {
  left: 0;
}
.rice-navbar__right.data-v-abe06922 {
  right: 0;
}
.rice-navbar__center.data-v-abe06922 {
  align-items: center;
  padding: 0 10px;
  box-sizing: border-box;
  width: 70%;
}
.rice-navbar__center--has-right.data-v-abe06922 {
  width: calc(70% - var(--97aa7a94));
}
.rice-navbar__title.data-v-abe06922 {
  width: 100%;
  font-size: var(--rice-font-size-md);
  color: var(--rice-text-color);
  font-weight: bold;
  text-align: center;
  white-space: nowrap;
  text-overflow: ellipsis;
}