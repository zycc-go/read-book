.rice-textarea.data-v-f05776ee {
  position: relative;
  border-radius: 4px;
  background-color: var(--rice-textarea-background);
  padding: 10px;
}
.rice-textarea__textarea.data-v-f05776ee {
  text-align: left;
  font-size: var(--rice-font-size-basic);
  color: var(--rice-text-color);
  width: 100%;
}
.rice-textarea__textarea--disabled.data-v-f05776ee {
  color: var(--rice-textarea-disabled-text-color);
}
.rice-textarea__textarea--center.data-v-f05776ee {
  text-align: center;
}
.rice-textarea__textarea--right.data-v-f05776ee {
  text-align: right;
}
.rice-textarea__count.data-v-f05776ee {
  position: absolute;
  right: 5px;
  bottom: 2px;
  font-size: 12px;
  background-color: var(--rice-textarea-background);
  color: var(--rice-text-color-2);
  padding: 1px 4px;
}
.rice-textarea__count--disabled.data-v-f05776ee {
  background-color: var(--rice-textarea-disabled-background);
  color: var(--rice-textarea-disabled-text-color);
}
.rice-textarea--surround.data-v-f05776ee {
  border-radius: 4px;
  border: 1px solid var(--rice-textarea-border-color);
}
.rice-textarea--bottom.data-v-f05776ee {
  border-bottom: 1px solid var(--rice-textarea-border-color);
}
.rice-textarea--disabled.data-v-f05776ee {
  background-color: var(--rice-textarea-disabled-background);
}