.rice-action-sheet.data-v-36d96d8c {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  z-index: 999;
  transition-property: transform, opacity;
  transform: translate(0px, 100%);
  background-color: var(--rice-action-sheet-menu-background);
}
.rice-action-sheet--opacity.data-v-36d96d8c {
  opacity: 0;
}
.rice-action-sheet__title.data-v-36d96d8c {
  position: relative;
  width: 100%;
  padding: var(--rice-padding-md);
  background-color: var(--rice-action-sheet-menu-background);
  flex-direction: row;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  word-break: break-all;
  cursor: default;
}
.rice-action-sheet__title.data-v-36d96d8c::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
  pointer-events: none;
  left: 0;
  right: 0;
  bottom: 0;
  border-bottom: 1px solid var(--rice-border-color);
  transform: scaleY(0.5);
}
.rice-action-sheet__title__text.data-v-36d96d8c {
  text-overflow: ellipsis;
  overflow: hidden;
  white-space: nowrap;
  width: 100%;
  text-align: center;
  font-size: var(--rice-font-size-basic);
  color: var(--rice-text-color-2);
  line-height: 1.4;
}
.rice-action-sheet__container.data-v-36d96d8c {
  max-height: 350px;
}
.rice-action-sheet__menu.data-v-36d96d8c {
  width: 100%;
  padding: var(--rice-padding-md);
  background-color: var(--rice-action-sheet-menu-background);
  flex-direction: row;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  word-break: break-all;
  color: var(--rice-text-color);
}
.rice-action-sheet__menu__text.data-v-36d96d8c {
  text-align: center;
  line-height: 1.4;
  max-width: 100%;
}
.rice-action-sheet__menu__subname.data-v-36d96d8c {
  width: 100%;
  color: var(--rice-text-color-2);
  font-size: 12px;
  margin-top: 6px;
  text-align: center;
  line-height: 1.4;
}
.rice-action-sheet__menu--disabled.data-v-36d96d8c {
  color: var(--rice-action-sheet-menu-disabled-text-color);
  cursor: not-allowed;
}
.rice-action-sheet__menu--disabled .rice-action-sheet__menu__subname.data-v-36d96d8c {
  color: var(--rice-action-sheet-menu-disabled-text-color);
}
.rice-action-sheet__menu--border.data-v-36d96d8c {
  position: relative;
}
.rice-action-sheet__menu--border.data-v-36d96d8c::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
  pointer-events: none;
  left: 0;
  right: 0;
  bottom: 0;
  border-bottom: 1px solid var(--rice-border-color);
  transform: scaleY(0.5);
}
.rice-action-sheet__gap.data-v-36d96d8c {
  background-color: var(--rice-action-sheet-background);
  height: 6px;
}
.rice-action-sheet__cancel.data-v-36d96d8c {
  width: 100%;
  padding: var(--rice-padding-md);
  background-color: var(--rice-action-sheet-menu-background);
  flex-direction: row;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  word-break: break-all;
}
.rice-action-sheet__cancel__text.data-v-36d96d8c {
  line-height: 1.4;
  color: var(--rice-action-sheet-cancel-text-color);
}
.rice-action-sheet--hover.data-v-36d96d8c {
  background-color: var(--rice-action-sheet-hover-background);
}