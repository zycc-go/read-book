.rice-dialog.data-v-13572bed {
  position: fixed;
  top: 50%;
  left: 50%;
  width: 320px;
  background-color: var(--rice-dialog-background);
  border-radius: 12px;
  opacity: 0;
  transform: translate(-50%, -50%) scale(0.8);
  transition-property: opacity, transform;
}
.rice-dialog__title.data-v-13572bed {
  align-items: center;
  padding: 24px var(--rice-padding-md) 0;
}
.rice-dialog__title__text.data-v-13572bed {
  width: 100%;
  font-size: 17px;
  font-weight: bold;
  text-align: center;
  color: var(--rice-text-color);
  lines: 2;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  /* 限制显示两行 */
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-all;
}
.rice-dialog__content.data-v-13572bed {
  justify-content: center;
  align-items: center;
  padding: 24px var(--rice-padding-md);
}
.rice-dialog__content--has-title.data-v-13572bed {
  padding-top: var(--rice-padding-md);
}
.rice-dialog__message.data-v-13572bed {
  max-height: 280px;
  width: 100%;
}
.rice-dialog__message__text.data-v-13572bed {
  font-size: var(--rice-font-size-md);
  color: var(--rice-dialog-message-text-color);
  line-height: 1.5;
  text-align: center;
  word-break: break-all;
}
.rice-dialog__message__left.data-v-13572bed {
  text-align: left;
}
.rice-dialog__message__right.data-v-13572bed {
  text-align: right;
}
.rice-dialog__footer.data-v-13572bed {
  flex-direction: row;
  width: 100%;
}
.rice-dialog__footer--border.data-v-13572bed {
  border-top: 1px solid var(--rice-border-color);
}
.rice-dialog__footer--vertical.data-v-13572bed {
  flex-flow: column-reverse;
}
.rice-dialog__footer--btn.data-v-13572bed {
  padding: 0 var(--rice-padding-md) 24px;
}
.rice-dialog__button.data-v-13572bed {
  height: 48px;
  flex: 1;
  align-items: center;
  justify-content: center;
}
.rice-dialog__button__text.data-v-13572bed {
  text-align: center;
  font-size: var(--rice-font-size-md);
  color: var(--rice-text-color);
  font-weight: bold;
}
.rice-dialog__button__text__confirm.data-v-13572bed {
  color: var(--rice-primary-color);
}
.rice-dialog__button--disabled.data-v-13572bed {
  opacity: 0.5;
}
.rice-dialog__button--border.data-v-13572bed {
  border-right: 1px solid var(--rice-border-color);
}
.rice-dialog__button--hover.data-v-13572bed {
  background-color: #f2f3f5;
}
.rice-dialog__button--hover--dark.data-v-13572bed {
  background-color: #3a3a3c;
}