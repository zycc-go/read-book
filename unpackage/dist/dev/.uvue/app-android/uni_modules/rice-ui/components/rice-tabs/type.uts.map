
import { BadgeProps } from "../rice-badge/type.uts"

export type TabsOptions = {
	name : string,
	value ?: string | number,
	disabled ?: boolean,
	badge ?: BadgeProps
}

export type TabsClickTab = {
	index : number,
	name : string,
	value ?: string | number,
	disabled : boolean,
}


export type TabsChange = {
	index : number,
	name : string,
	value ?: string | number,
	disabled : boolean,
}

export type TabsItemRect = {
	x : number,
	w : number
}

export type TabsProps = {
	list : TabsOptions[],
	shrink ?: boolean,
	lineMode ?: 'slide' | 'zoom',
	titleActiveColor ?: string,
	titleInactiveColor ?: string,
	initAnimate ?: boolean,
	bgColor ?: string,
	height ?: string | number,
	lineColor ?: string,
	lineWidth ?: string | number,
	lineHeight ?: string | number,
	textClass ?: string,
	activeTextClass ?: string,
	inactiveTextClass ?: string,
	disabledTextClass ?: string,
	itemStyle ?: UTSJSONObject,
	activeStyle ?: UTSJSONObject,
	inactiveStyle ?: UTSJSONObject,
	customStyle ?: UTSJSONObject,
}