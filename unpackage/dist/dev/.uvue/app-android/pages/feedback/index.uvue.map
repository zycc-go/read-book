<template>
	<view :class="[`theme-${state.appTheme}`, 'page']" :style="style">
		<my-navbar leftArrow title="反馈" />

		<view class="card">
			<textarea class="textarea-instance" placeholder="请输入内容" :maxlength="500" :auto-focus="true"
				:auto-height="true" :value="content" @input="onInput" />
			<button class="btn" type="primary" @tap="onSubmit">提交</button>
		</view>
	</view>
</template>

<script setup lang="uts">
	import { state } from '@/store/index.uts'
	import MyNavbar from '@/componnets/MyNavbar.uvue';

	const style = computed(() => {
		return {
			paddingTop: state.statusBarHeight + state.navbarHeight + 'px',
			paddingBottom: state.safeAreaInsetsHeight + 'px',
		};
	})

	const content = ref<string>('')

	const onInput = (event : UniInputEvent) => {
		content.value = event.detail.value
	}

	const onSubmit = () => {
		// console.log('value', content.value)
		if (content.value.length <= 0) {
			uni.showToast({ title: '请输入内容', icon: 'error' })
			return
		}
		uni.showLoading()
		setTimeout(() => {
			// 这里是提交操作
			uni.hideLoading()
		}, 1000)
	}
</script>

<style lang="scss" scoped>
	.page {
		background-color: var(--navbar-background);
		height: 100%;
		width: 100%;
	}

	.card {
		padding: $uni-spacing-col-lg $uni-spacing-row-lg;

		.textarea-instance {
			min-height: 140px;
			width: 100%;
			padding: $uni-spacing-col-12 $uni-spacing-row-12;
			border-radius: $uni-border-radius-8;
			font-size: $uni-font-size-base;
			color: var(--text-color-1);
			line-height: $uni-line-height-24;
			background-color: var(--background-color-3);
		}

		.btn {
			margin-top: $uni-spacing-col-12;
		}
	}
</style>