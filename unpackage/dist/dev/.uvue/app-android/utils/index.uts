import { state } from '@/store/index.uts';
export const getRandomDigits = (n: number): string => {
    let result = '';
    // 1. 先确定第一位 (1-9)，防止出现 0 开头导致位数不够
    result += Math.floor(Math.random() * 9) + 1;
    // 2. 剩下的直接循环拼接，避开浮点数乘法
    for (let i = 1; i < n; i++) {
        result += Math.floor(Math.random() * 10);
    }
    return result;
};
// 添加单位
export const addUnit = (value: number | string): string => {
    const isNumeric = typeof value == 'number' || /^\d+(\.\d+)?$/.test(value as string);
    return isNumeric ? `${value}${state.unit}` : (value as string).toString();
};
// 判断字符串是否有值
export const hasStrValue = (val?: string | number | null): boolean => {
    if (val == null)
        return false;
    if (typeof val != 'string') {
        val = (val as number).toString();
    }
    return (val as string).trim().length > 0;
};
// 判断 URL 对应的文件是否为图片
export const isImage = (url?: string): boolean => {
    if (url == null)
        return false;
    const imageExtensions = /\.(jpg|jpeg|png|gif|bmp|webp|svg|ico)$/i;
    return imageExtensions.test(url);
};
// 判断 URL 对应的文件是否为视频
export const isVideo = (url?: string): boolean => {
    if (url == null)
        return false;
    const videoExtensions = /\.(mp4|webm|ogg|mov|avi|wmv|flv|mkv)$/i;
    return videoExtensions.test(url);
};
