<template>
	<view :class="`rice-theme-${state.appTheme}`">
		<rice-navbar :left-arrow="false" :height="state.navbarHeight">
			<template #right>
				<view class="nav-right">
					<rice-icon name="search" class="nav-icon" @click="onSearch" />
					<rice-icon name="bars" class="nav-icon" @click="onShowMenu" />
				</view>
			</template>
		</rice-navbar>

		<!-- 书籍列表 -->
		<scroll-view class="book-list" scroll-y>
			<view v-if="bookList.length === 0" class="empty">
				<rice-empty description="书架空空如也，快去添加书籍吧" />
			</view>

			<view v-else class="book-grid">
				<rice-grid>
					<rice-grid-item v-for="(book, index) in bookList" :key="index" @click="onBookClick(book)">
						<template #default>
							<view class="book-cover">
								<image :src="book.cover" mode="aspectFill" />
							</view>
							<text class="book-title">{{ book.title }}</text>
							<text class="book-author">{{ book.author }}</text>
							<view class="book-actions">
								<rice-icon v-if="book.hasUnread" name="dot" size="12" color="#d81e06" />
								<text v-if="book.lastChapter" class="last-chapter">{{ book.lastChapter }}</text>
							</view>
						</template>
					</rice-grid-item>
				</rice-grid>
			</view>
		</scroll-view>
	</view>

	<PopupMenu ref="popupMenuRef" />
</template>

<script setup lang="uts">
	import { setTheme, showActionSheet, ActionSheetAction } from "@/uni_modules/rice-ui"
	import { state, setAppTheme } from '@/store/index.uts'
	import { bookList } from '@/data/book'
	import PopupMenu from './popup-menu.uvue'

	const popupMenuRef = ref<any>(null)

	const onShowMenu = () => {
		if (popupMenuRef.value) {
			popupMenuRef.value.openShowMenu()
		}
	}

	const onSearch = () => {
		uni.navigateTo({
			url: '/pages/search/index'
		})
	}

	const onBookClick = (book : any) => {
		uni.navigateTo({
			url: `/pages/library/index?bookId=${book.id}`
		})
	}
</script>

<style lang="scss" scoped>
	.nav-right {
		display: flex;
		flex-direction: row;
		margin-right: $uni-spacing-row-lg;

		.nav-icon {
			font-size: $uni-img-size-base;
			margin-left: $uni-spacing-row-base;
			color: var(--rice-text-color);
		}
	}

	.header {
		margin: $uni-spacing-col-lg $uni-spacing-row-lg;
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;

		.h-left {
			display: flex;
			flex-direction: column;
		}

		.h-text1 {
			font-size: $uni-font-size-lg;
			font-weight: bold;
			color: var(--rice-text-color);
		}

		.h-text2 {
			margin-top: $uni-spacing-col-sm;
			font-size: $uni-font-size-sm;
			color: var(--rice-text-color-2);
		}

		.h-right {
			.rice-button {
				padding: $uni-spacing-col-sm $uni-spacing-row-sm;
			}
		}
	}

	.category-scroll {
		height: 80rpx;
		white-space: nowrap;

		.category-list {
			display: flex;
			flex-direction: row;
			padding: $uni-spacing-col-base $uni-spacing-row-base;

			.category-item {
				display: inline-block;
				padding: $uni-spacing-col-sm $uni-spacing-row-lg;
				margin-right: $uni-spacing-row-base;
				font-size: $uni-font-size-base;
				color: var(--rice-text-color-2);
				background-color: var(--rice-bg-color-2);
				border-radius: 50rpx;

				&:last-child {
					margin-right: 0;
				}

				&.category-active {
					background-color: var(--rice-color-primary);
					color: #fff;
					font-weight: 500;
				}
			}
		}
	}

	.book-list {
		flex: 1;

		.empty {
			padding: $uni-spacing-col-lg * 2;
			text-align: center;
		}

		.book-grid {
			display: flex;
			flex-wrap: wrap;
			padding: $uni-spacing-col-base;
			justify-content: space-between;

			.book-item {
				width: 48%;
				margin-bottom: $uni-spacing-col-lg;

				.book-cover {
					width: 100%;
					padding-top: 150%;
					position: relative;
					border-radius: $uni-border-radius-base;
					overflow: hidden;
					background-color: var(--rice-bg-color-2);
					box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);

					image {
						position: absolute;
						top: 0;
						left: 0;
						width: 100%;
						height: 100%;
					}

					.cover-placeholder {
						position: absolute;
						top: 0;
						left: 0;
						width: 100%;
						height: 100%;
						display: flex;
						justify-content: center;
						align-items: center;
						background-color: var(--rice-bg-color-2);

						.cover-text {
							font-size: $uni-font-size-lg;
							color: var(--rice-text-color-2);
						}
					}

					.progress-bar {
						position: absolute;
						bottom: 0;
						left: 0;
						width: 100%;
						height: 6rpx;
						background-color: rgba(0, 0, 0, 0.1);

						.progress-fill {
							height: 100%;
							background-color: var(--rice-color-primary);
							transition: width 0.3s;
						}
					}
				}

				.book-title {
					display: block;
					margin-top: $uni-spacing-col-base;
					font-size: $uni-font-size-base;
					color: var(--rice-text-color);
					overflow: hidden;
					text-overflow: ellipsis;
					display: -webkit-box;
					-webkit-line-clamp: 2;
					-webkit-box-orient: vertical;
					line-height: 1.4;
				}

				.book-author {
					display: block;
					margin-top: $uni-spacing-col-sm;
					font-size: $uni-font-size-sm;
					color: var(--rice-text-color-2);
				}

				.book-actions {
					display: flex;
					align-items: center;
					margin-top: $uni-spacing-col-sm;

					.rice-icon {
						margin-right: $uni-spacing-col-sm;
					}

					.last-chapter {
						font-size: $uni-font-size-xs;
						color: var(--rice-text-color-2);
						overflow: hidden;
						text-overflow: ellipsis;
						white-space: nowrap;
						max-width: 200rpx;
					}
				}
			}
		}
	}

	.bottom-bar {
		padding: $uni-spacing-col-lg $uni-spacing-row-lg;
		border-top: 1px solid var(--rice-border-color);

		.rice-button {
			height: 88rpx;
			line-height: 88rpx;
			border-radius: $uni-border-radius-circle;
			font-weight: 500;
		}
	}
</style>