<template>
	<view :class="`rice-theme-${state.appTheme}`" class="page">
		<rice-navbar :height="state.navbarHeight" title="设置" @clickLeft="onClickLeft" />

		<view class="card">
			<rice-cell-group radius="8px">
				<rice-cell title="深色模式">
					<template #rightIcon>
						<rice-switch v-model="isDark" @change="onChangeIsDark"></rice-switch>
					</template>
				</rice-cell>
				<rice-cell title="跟随系统设置" label="开启后，自动跟随系统外观模式设置">
					<template #rightIcon>
						<rice-switch v-model="isFollowSystem" @change="onChangeIsFollowSystem"></rice-switch>
					</template>
				</rice-cell>
			</rice-cell-group>
		</view>
	</view>
</template>

<script setup lang="uts">
	import { setTheme } from "@/uni_modules/rice-ui"
	import { state, setAppTheme } from '@/store/index.uts'

	const isDark = ref<boolean>(false)
	const isFollowSystem = ref<boolean>(false)

	const onChangeIsDark = (value : boolean) => {
		isDark.value = value
		if (value) {
			isFollowSystem.value = false
		}
	}

	const onChangeIsFollowSystem = (value : boolean) => {
		isFollowSystem.value = value
		if (value) {
			isDark.value = false
		}
	}

	const onClickLeft = () => {



		uni.switchTab({ url: '/pages/mine/index' })
	}
</script>

<style lang="scss" scoped>
	.page {
		background-color: var(--rice-navbar-background);
		height: 100%;
		width: 100%;
	}

	.card {
		padding: $uni-spacing-col-lg $uni-spacing-row-lg;

		:deep(.rice-icon) {
			display: flex;
			align-items: center;
		}
	}
</style>