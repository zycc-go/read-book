export type FloatPanelProps = {
	exposedHeight ?: string | number,//默认露出的高度，单位px，rpx和%
	contentDraggable ?: boolean, //允许拖拽内容容器,为false 时，只能拖拽rice-float-panel__header
	duration ?: number, //动画时长
	zIndex ?: number, //zIndex的值
	radius ?: number | string, //圆角
	scrollTargetId ?: string, //内部滚动容器的id
	popupClass ?: string,
}