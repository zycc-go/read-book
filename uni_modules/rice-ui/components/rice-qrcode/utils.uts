import { QRBitBuffer, QRPolynomial, QRRSBlock } from './type.uts'

const qrPad0 = 0xEC
const qrPad1 = 0x11
const qrMode8BitByte = 4
const qrG15 = 1335
const qrG18 = 7973
const qrG15Mask = 21522

